{
  "name": "meridian",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Meridian — a personal long-term Indian-equity stock picker. Cloudflare Worker + Static Assets + D1. Live screen/company data from Screener.in (on demand), live price/charts from Yahoo Finance.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute meridian-db --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute meridian-db --local --file=./schema.sql",
    "ingest": "node scripts/ingest.mjs",
    "db:seed:real": "wrangler d1 execute meridian-db --remote --file=./seed.real.sql",
    "db:seed:real:local": "wrangler d1 execute meridian-db --local --file=./seed.real.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
